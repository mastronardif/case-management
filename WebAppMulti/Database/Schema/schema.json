{
  "apis": [
    {
      "name": "searchCases",
      "type": "storedProcedure",
      "storedProcedure": "cases.usp_SearchCases",
      "route": "/api/corqs/searchCases"
    },
    {
      "name": "getCalendar",
      "type": "storedProcedure",
      "storedProcedure": "cases.usp_GetCalendar",
      "route": "/api/corqs/getCalendar"
    },
    {
      "name": "getServerTime",
      "type": "handler",
      "handler": "ServerTime",
      "route": "/api/corqs/getServerTime"
    },
    {
      "name": "getUser",
      "type": "http",
      "url": "https://jsonplaceholder.typicode.com/users/{id}",
      "method": "GET",
      "route": "/api/corqs/getUser"
    },
    {
      "name": "activeCases",
      "type": "sql",
      "sql": "SELECT TOP 100 * FROM [cases].[Case] WHERE Status = @Status ORDER BY CreatedDate DESC",
      "route": "/api/corqs/activeCases"
    },

    {
      "name": "getBooks",
      "type": "handler",
      "handler": "GetBooks",
      "route": "/api/corqs/getBooks"
    },
    {
      "name": "getBook",
      "type": "handler",
      "handler": "GetBook",
      "routeNA": "/api/corqs/getBookZZZZZZZZZZZZZZZZZZ",
      "params": {
        "caseId": {
          "type": "string",
          "required": true,
          "source": "body"
        },
        "fileName": {
          "type": "string",
          "required": true,
          "source": "body"
        }
      }

    },

    {
      "name": "getWorkbooksByCase",
      "type": "storedProcedure",
      "storedProcedure": "cases.usp_Workbook_GetByCaseId",
      "route": "/api/corqs/cases/{caseId}/workbooks"
    },
    {
      "name": "initializeWorkbooks",
      "type": "storedProcedure",
      "storedProcedure": "cases.usp_Workbook_InitializeForCase",
      "route": "/api/corqs/cases/{caseId}/workbooks/init"
    }


  ]
}
